// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Site {
  id        String   @id @default(cuid())
  name      String
  domain    String
  apiKey    String   @unique @default(cuid())
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      TranslationLog[]
  languages SiteLanguage[]
  messages  SiteMessages[]
}

model SiteMessages {
  id        String   @id @default(cuid())
  siteId    String
  locale    String
  messages  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, locale])
}

model Language {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isSource  Boolean  @default(false)
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sites     SiteLanguage[]
}

model SiteLanguage {
  id         String   @id @default(cuid())
  siteId     String
  languageId String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  site     Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([siteId, languageId])
  @@index([siteId])
}

model Provider {
  id              String   @id @default(cuid())
  name            String   @unique
  displayName     String
  apiKey          String   @default("")
  model           String?
  active          Boolean  @default(true)
  isDefault       Boolean  @default(false)
  costPerChar     Float    @default(0)
  // Free quota tracking — auto fallback to next provider when reached
  freeQuotaUsed   Int      @default(0)
  freeQuotaLimit  Int      @default(0)   // 0 = unlimited (paid or self-hosted)
  quotaResetAt    DateTime?
  // Routing hints
  priority        Int      @default(100) // lower number = higher priority
  maxCharsPerCall Int      @default(5000)
  supportsBatch   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  logs            TranslationLog[]
}

model TranslationLog {
  id          String   @id @default(cuid())
  siteId      String?
  providerId  String?
  fromLang    String   @default("ko")
  toLang      String
  inputChars  Int
  outputChars Int      @default(0)
  durationMs  Int
  cost        Float    @default(0)
  cacheHit    Boolean  @default(false)
  success     Boolean  @default(true)
  error       String?
  createdAt   DateTime @default(now())

  site     Site?     @relation(fields: [siteId], references: [id])
  provider Provider? @relation(fields: [providerId], references: [id])

  @@index([createdAt])
  @@index([siteId, createdAt])
}

// Translation memory — every successful translation is cached.
// Lookup is O(1) via the unique (textHash, fromLang, toLang) index.
model TranslationCache {
  id          String   @id @default(cuid())
  textHash    String   // SHA-256 of source text
  fromLang    String
  toLang      String
  sourceText  String   @db.Text
  translated  String   @db.Text
  provider    String
  hits        Int      @default(0)
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @default(now())

  @@unique([textHash, fromLang, toLang])
  @@index([lastUsedAt])
}
