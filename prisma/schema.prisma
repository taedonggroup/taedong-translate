// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Site {
  id        String   @id @default(cuid())
  name      String
  domain    String
  apiKey    String   @unique @default(cuid())
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      TranslationLog[]
  languages SiteLanguage[]
  messages  SiteMessages[]
}

model SiteMessages {
  id        String   @id @default(cuid())
  siteId    String
  locale    String
  messages  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, locale])
}

model Language {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isSource  Boolean  @default(false)
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sites     SiteLanguage[]
}

model SiteLanguage {
  id         String   @id @default(cuid())
  siteId     String
  languageId String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  site     Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([siteId, languageId])
  @@index([siteId])
}

model Provider {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  apiKey      String   @default("")   // encrypted or plain API key
  model       String?                  // "claude-haiku-4-5-20251001" etc
  active      Boolean  @default(true)
  isDefault   Boolean  @default(false)
  costPerChar Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  logs        TranslationLog[]
}

model TranslationLog {
  id          String   @id @default(cuid())
  siteId      String?
  providerId  String?
  fromLang    String   @default("ko")
  toLang      String
  inputChars  Int
  outputChars Int      @default(0)
  durationMs  Int
  cost        Float    @default(0)
  success     Boolean  @default(true)
  error       String?
  createdAt   DateTime @default(now())

  site     Site?     @relation(fields: [siteId], references: [id])
  provider Provider? @relation(fields: [providerId], references: [id])
}
