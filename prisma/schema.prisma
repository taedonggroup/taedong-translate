// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Site {
  id        String   @id @default(cuid())
  name      String
  domain    String
  apiKey    String   @unique @default(cuid())
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      TranslationLog[]
}

model Language {
  id        String   @id @default(cuid())
  code      String   @unique  // "ko", "en", "ja", "zh", "vi", "th"
  name      String             // "한국어", "English", "日本語"
  isSource  Boolean  @default(false)  // true = 원본 언어 (ko)
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Provider {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  apiKey      String   @default("")   // encrypted or plain API key
  model       String?                  // "claude-haiku-4-5-20251001" etc
  active      Boolean  @default(true)
  isDefault   Boolean  @default(false)
  costPerChar Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  logs        TranslationLog[]
}

model TranslationLog {
  id          String   @id @default(cuid())
  siteId      String?
  providerId  String?
  fromLang    String   @default("ko")
  toLang      String
  inputChars  Int
  outputChars Int      @default(0)
  durationMs  Int
  cost        Float    @default(0)
  success     Boolean  @default(true)
  error       String?
  createdAt   DateTime @default(now())

  site     Site?     @relation(fields: [siteId], references: [id])
  provider Provider? @relation(fields: [providerId], references: [id])
}
